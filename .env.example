# ====== NovelFactory — Environment Configuration ======
# Copy to .env and fill in your values

# ====== Version (统一版本管理) ======
# 通过环境变量统一设置版本号，覆盖 settings.py 默认值
NOVELFACTORY_VERSION=7.8.0

# ====== Database ======
POSTGRES_USER=noveluser
POSTGRES_PASSWORD=novelpass2024
POSTGRES_DB=novelfactory
POSTGRES_PORT=5434
DB_HOST=postgres
DB_PORT=5432
DB_NAME=novelfactory
DB_USER=noveluser
DB_PASSWORD=novelpass2024

# ====== Redis ======
REDIS_PASSWORD=novelredis2024
REDIS_PORT=6380
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379
REDIS_DB=0

# ====== LLM Keys ======
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====== SiliconFlow (Embedding + Fallback LLM) ======
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====== MiniMax (optional) ======
MINIMAX_API_KEY=sk-cp-xxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_GROUP_ID=

# ====== Feishu / Lark ======
LARK_APP_ID=cli_xxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ROOT_FOLDER=
FEISHU_CHAT_ID=
LARK_PROXY_URL=http://tools_proxy:5004

# ====== Channel Service (Feishu WebSocket) ======
# 启用渠道层（FeishuChannel WebSocket 长连接），默认 true
# 关闭则使用传统的 FeishuToolkit → tools-proxy 路径
CHANNELS_ENABLED=true

# ====== Embedding — SiliconFlow Qwen3-Embedding-0.6B (1024d) ======
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMS=1024

# ====== Neo4j ======
NEO4J_HOST=langgraph_neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=novelgraph2024
NEO4J_BOLT_PORT=7687
NEO4J_HTTP_PORT=7474
NEO4J_PAGE_CACHE=512M
NEO4J_HEAP_INIT=512M
NEO4J_HEAP_MAX=1G

# ====== Storage ======
STORE_TYPE=postgres
CHECKPOINT_TYPE=postgres
STORAGE_TYPE=local
STORAGE_PATH=/data

# ====== App ======
# 内部 API 地址（容器内，event_handler.py 通过此地址自调用 API）
BASE_URL=http://localhost:8000
# 飞书回调验证（请从飞书开放平台 → 应用 → 事件与回调 → 回调配置 中获取）
# 只有配置了 FEISHU_VERIFICATION_TOKEN 才会验证飞书回调请求
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
LOG_LEVEL=INFO
RESTART_POLICY=unless-stopped
NGINX_PORT=8081
NGINX_SSL_PORT=8443
API_PORT=8123

# ====== LLM Timeout ======
LLM_REQUEST_TIMEOUT=900

# ====== Quota ======
QUOTA_THRESHOLD=5.0
QUOTA_CHECK_BEFORE_CALL=false
QUOTA_CHECK_INTERVAL_SECONDS=60.0

# ====== DB Pool ======
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_CONNECT_TIMEOUT=30
DB_STATEMENT_TIMEOUT=30000

# ====== Pricing (CNY per million tokens) ======
DEEPSEEK_PRICE_INPUT=0.5
DEEPSEEK_PRICE_OUTPUT=2.0
DEEPSEEK_PRICE_DEFAULT_INPUT=0.5
DEEPSEEK_PRICE_DEFAULT_OUTPUT=2.0

# ====== 3rd LLM Fallback ======
OPENAI_API_KEY=
OPENAI_BASE_URL=

# ====== Milvus ======
MILVUS_HOST=langgraph_milvus
MILVUS_PORT=19530
MILVUS_MEM_LIMIT=4

# ====== Monitoring ======
FEISHU_ALERT_WEBHOOK=
ALERT_MIN_LEVEL=ERROR
AUDIT_LOG_DIR=/data/audit
AUDIT_LOG_ENABLED=true
NOVELFACTORY_LOG_PATH=/data/logs/novelfactory.log
NOVELFACTORY_ENV=production
LOG_FORMAT=json